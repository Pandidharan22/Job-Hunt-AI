# EditorConfig — JobHunt AI · https://editorconfig.org
# Editor defaults aligned with the project's tooling (ruff line-length 100,
# Prettier/ESLint 2-space, YAML 2-space). Stops here — do not look in parent dirs.
root = true

# --- Defaults for every file ---------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

# --- Python (PEP 8 / ruff: 4-space indent, 100-col) ----------------------------
[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 100

# --- TypeScript / JavaScript (2-space) -----------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# --- JSON (2-space) ------------------------------------------------------------
[*.{json,jsonc}]
indent_size = 2

# --- YAML (2-space; YAML forbids tabs) -----------------------------------------
[*.{yml,yaml}]
indent_size = 2

# --- Markdown (2-space; keep trailing whitespace = hard line breaks) -----------
[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false

# --- TOML (pyproject.toml etc.) ------------------------------------------------
[*.toml]
indent_size = 4

# --- Web assets ----------------------------------------------------------------
[*.{html,css,scss}]
indent_size = 2

# --- Shell scripts -------------------------------------------------------------
[*.sh]
indent_size = 2

# --- Makefiles require real tabs -----------------------------------------------
[{Makefile,makefile,*.mk}]
indent_style = tab

# --- Windows scripts use CRLF --------------------------------------------------
[*.{bat,cmd}]
end_of_line = crlf
